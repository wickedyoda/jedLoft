# Container image published to GitHub Container Registry.
IMAGE_NAME=ghcr.io/wickedyoda/jedloft:latest

# Host ports.
WEB_PORT=8000
MYSQL_PORT=3306

# Database settings used by the application and mysql container.
MYSQL_DATABASE=jedloft
MYSQL_USER=jedloft
MYSQL_PASSWORD=jedloft
MYSQL_ROOT_PASSWORD=rootpass
DATABASE_URL=mysql+pymysql://jedloft:jedloft@db:3306/jedloft

# Application runtime.
SESSION_SECRET=change-this-to-a-long-random-string
LOG_DIR=/logs
MOBILE_ALLOWED_ORIGINS=*

# Default bootstrap admin account.
DEFAULT_ADMIN_NAME=System Admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=AdminAA1
