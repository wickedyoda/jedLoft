# Container image published to GitHub Container Registry.
IMAGE_NAME=ghcr.io/wickedyoda/jedloft:latest

# Host ports.
WEB_PORT=8000
POSTGRES_PORT=5432

# Database settings used by the application and postgres container.
POSTGRES_DB=jedloft
POSTGRES_USER=jedloft
POSTGRES_PASSWORD=jedloft
DATABASE_URL=postgresql+psycopg://jedloft:jedloft@db:5432/jedloft

# Application runtime.
SESSION_SECRET=change-this-to-a-long-random-string
LOG_DIR=/logs

# Default bootstrap admin account.
DEFAULT_ADMIN_NAME=System Admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=AdminAA1
